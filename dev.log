      'COPY . .\n' +
      'RUN CGO_ENABLED=0 go build -o server .\n' +
      '\n' +
      'FROM alpine:latest\n' +
      'COPY --from=builder /app/server /server\n' +
      'EXPOSE 8080\n' +
      'CMD ["/server"]\n' +
      '```\n' +
      'Tags: docker,go,devops\n' +
